[Unit]
Description=ShotFlow MCP Server
After=network.target shotflow.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/shotflow-mcp
ExecStart=/usr/bin/node shotflow-mcp-server.js
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production
Environment=SHOTFLOW_API_URL=http://localhost:3003
Environment=MCP_PORT=3004

[Install]
WantedBy=multi-user.target
